{
  "name": "easy-pay-monorepo",
  "version": "2.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "docker-compose up backend",
    "dev:mobile": "cd apps/mobile-app && npm start",
    "dev:web": "npm run dev --workspace=apps/web-app",
    "dev": "npm run /^dev:*/",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules package-lock.json && npm install",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-worklets-core": "1.6.3",
    "react-native-reanimated": "4.2.2",
    "@react-navigation/native": "7.1.33",
    "@react-navigation/core": "7.16.1"
  }
}
