{
  "name": "easy-pay-monorepo",
  "version": "2.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "pnpm install",
    "dev:backend": "docker-compose up backend",
    "dev:mobile": "pnpm --filter mobile-app start",
    "dev:web": "pnpm --filter web-app dev",
    "dev": "pnpm run /^dev:*/",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && pnpm install",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.1",
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native-worklets-core": "1.6.3",
      "react-native-reanimated": "4.2.2",
      "@react-navigation/native": "7.1.33",
      "@react-navigation/core": "7.16.1"
    },
    "ignoredBuiltDependencies": []
  }
}
