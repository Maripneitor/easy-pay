{
  "name": "easy-pay-monorepo",
  "version": "2.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:backend": "docker-compose up backend",
    "dev:mobile": "cd apps/mobile-app && npm start",
    "dev:web": "npm run dev --workspace=apps/web-app",
    "dev": "npm run /^dev:*/",
    "clean": "npx rimraf node_modules apps/*/node_modules packages/*/node_modules package-lock.json && npm install",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.574.0",
    "react-router-dom": "^7.1.3",
    "tailwind-merge": "^3.0.0",
    "expo": "~52.0.25",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.6"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native-reanimated": "~3.16.1"
  }
}
